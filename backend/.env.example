# ============================================
# OrderDabaly Backend - Environment Variables
# ============================================

# -------------------- Database --------------------
DATABASE_URL=postgresql://username:password@localhost:5432/orderdabaly

# -------------------- Stripe --------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# -------------------- Email Notifications (AWS SES) --------------------
# AWS Simple Email Service credentials for main platform emails
# (User registration, order confirmations, welcome emails, etc.)
# Get your credentials from: https://console.aws.amazon.com/iam/
# Make sure to verify your sender email in SES console
# https://console.aws.amazon.com/ses/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here
AWS_SES_FROM_EMAIL=noreply@orderdabaly.com
AWS_SES_FROM_NAME=Order Dabaly

# -------------------- SMTP (Optional - For Restaurant Notifications) --------------------
# Optional SMTP configuration for restaurant owner notifications
# If not configured, restaurant notifications via NotificationService will be disabled
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com

# -------------------- SMS Notifications (Twilio) --------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here_32_chars
TWILIO_PHONE_NUMBER=+1234567890

# -------------------- Google Maps API --------------------
# Required for delivery fee calculation based on distance
# Get your API key from: https://console.cloud.google.com/
# Enable: Geocoding API and Distance Matrix API
GOOGLE_MAPS_API_KEY=AIzaSyXxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------- Frontend URL --------------------
FRONTEND_URL=http://localhost:3000

# -------------------- Server --------------------
PORT=5001
NODE_ENV=development
